      <column caption='Normalised Runner-up Seed' datatype='real' name='[Calculation_1133499790161174543]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Runner-up Seed] - {FIXED : MIN([Runner-up Seed])})&#13;&#10;/ ({FIXED : MAX([Runner-up Seed])} - {FIXED : MIN([Runner-up Seed])})' />
      </column>
      <column caption='Normalised Winrate' datatype='real' name='[Calculation_1133499790165258257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Winrate] - {FIXED : MIN([Winrate])})&#13;&#10;/&#13;&#10;({FIXED : MAX([Winrate])} - {FIXED : MIN([Winrate])})' />
      </column>
      <column caption='Champins by country' datatype='integer' name='[Calculation_1133499790171500562]' role='measure' type='quantitative'>
