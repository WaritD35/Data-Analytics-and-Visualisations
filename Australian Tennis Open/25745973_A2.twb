    <worksheet name='Winrate Trend'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Winrate of the champions Trends in Australian Open Finals (1905–2025)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Australian Open (25745973_A2)' name='federated.0yaib4l0izniq317hr4h0178qbkk' />
          </datasources>
          <datasource-dependencies datasource='federated.0yaib4l0izniq317hr4h0178qbkk'>
            <column datatype='real' name='[Winrate]' role='measure' type='quantitative' />
            <column datatype='date' name='[Year]' role='dimension' type='ordinal' />
            <column-instance column='[Winrate]' derivation='Avg' name='[avg:Winrate:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Year]' derivation='Year' name='[yr:Year:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' field='[federated.0yaib4l0izniq317hr4h0178qbkk].[avg:Winrate:qk]' field-type='quantitative' max='0.81935788571106716' min='0.014693273894660908' range-type='fixed' scope='rows' type='space' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <trendline enable-confidence-bands='false' enable-instant-analytics='true' enabled='true' exclude-color='false' exclude-intercept='false' fit='linear' />
          </pane>
        </panes>
        <rows>[federated.0yaib4l0izniq317hr4h0178qbkk].[avg:Winrate:qk]</rows>
        <cols>[federated.0yaib4l0izniq317hr4h0178qbkk].[yr:Year:ok]</cols>
        <annotations>
          <annotation class='point' id='0' mark-position='1' pullback='0' text-width='180'>
            <formatted-text>
              <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>The average win rate has gradually declined over the years, suggesting that finals have become more competitive, with champions winning by narrower margins.</run>
            </formatted-text>
            <point>
