      <column caption='Normalised Champion Seed' datatype='real' name='[Calculation_1133499790161145870]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Champion Seed] - {FIXED : MIN([Champion Seed])})&#13;&#10;/ ({FIXED : MAX([Champion Seed])} - {FIXED : MIN([Champion Seed])})' />
