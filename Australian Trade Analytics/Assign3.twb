              <flipboard active-id='6' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Australia’s trade has grown steadily since 1990, driven by mining and machinery exports.' captured-sheet='Trade Overview' id='1'>
                    <capturedDeltas>
                      <worksheet name='Import and Export of Main Categories in Time series'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.0tebqf80gcdcvf1b2vabe0st27lx].[usr:Calculation_1499417203940110346:qk:3]' field-type='quantitative' max='1.04500155129931' min='-0.027884558052801767' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.0tebqf80gcdcvf1b2vabe0st27lx].[none:Year (Unpivot-RAW-dataset):qk]' field-type='quantitative' max='2025' min='1986' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
