    <worksheet name='YoY Growth - subcategory'>
      <table>
        <view>
          <datasources>
            <datasource caption='25745973 - Unpivot Raw Dataset' name='federated.0tebqf80gcdcvf1b2vabe0st27lx' />
          </datasources>
          <datasource-dependencies datasource='federated.0tebqf80gcdcvf1b2vabe0st27lx'>
            <column caption='YoY Growth (%)' datatype='real' name='[Calculation_1499417203979845651]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF LOOKUP(SUM([Trade Value ($)]), -1) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;    ((SUM([Trade Value ($)]) - LOOKUP(SUM([Trade Value ($)]), -1))&#13;&#10;     / ABS(LOOKUP(SUM([Trade Value ($)]), -1))) &#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Subcategory]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Trade Value ($)]' role='measure' type='quantitative' />
            <column datatype='string' name='[Type (Unpivot-RAW-dataset)]' role='dimension' type='nominal' />
