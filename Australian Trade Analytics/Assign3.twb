      <aliases enabled='yes' />
      <column caption='True Trade Balance' datatype='integer' name='[Calculation_1499417203913760774]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Type (Unpivot-RAW-dataset)] = &quot;Import&quot; THEN -ABS([Trade Balance ($)])&#13;&#10;ELSE ABS([Trade Balance ($)])&#13;&#10;END' />
      </column>
      <column caption='Balance Status' datatype='string' name='[Calculation_1499417203914182663]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1499417203913760774] &gt;= 0 THEN &quot;Surplus&quot;&#13;&#10;ELSE &quot;Deficit&quot;&#13;&#10;END' />
      </column>
      <column caption='Import Share (%)' datatype='real' name='[Calculation_1499417203940110346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Import]) / TOTAL(SUM([Import]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Export Share (%)' datatype='real' name='[Calculation_1499417203944640527]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Export]) / TOTAL(SUM([Export]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Year Filter' datatype='boolean' name='[Calculation_1499417203965501458]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Year (Unpivot-RAW-dataset)] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='YoY Growth (%)' datatype='real' name='[Calculation_1499417203979845651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF LOOKUP(SUM([Trade Value ($)]), -1) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;    ((SUM([Trade Value ($)]) - LOOKUP(SUM([Trade Value ($)]), -1))&#13;&#10;     / ABS(LOOKUP(SUM([Trade Value ($)]), -1))) &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_1499417203983659029]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YoY Growth = [Trade Value ($)] / LOOKUP([Trade Value ($)], -1)' />
      </column>
