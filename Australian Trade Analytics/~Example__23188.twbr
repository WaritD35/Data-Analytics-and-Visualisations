          <formatted-text>
            <run bold='true' fontname='Arial' fontsize='16'>AUSTRALIA IMPORT AND EXPORT BY CATEGORY (1988-2023)</run>
          </formatted-text>
        </zone>
        <zone h='6901' id='16' name='Balance Value' show-title='false' w='22987' x='76720' y='54297' />
        <zone h='14844' id='17' name='Trade Value' show-title='false' w='22767' x='76794' y='38281' />
        <zone forceUpdate='true' h='3906' id='18' type-v2='text' w='22840' x='76720' y='52734'>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Arial' fontsize='14'>Balance</run>
