                                  <tuple>
                                    <value>31307861111.111111</value>
                                    <value>&quot;32 Coal, coke and briquettes ;&quot;</value>
                                    <value>&quot;Export&quot;</value>
                                    <value>1127083000000</value>
                                  </tuple>
                                </tuple-reference>
                              </visual-coordinate>
                            </point>
                            <body x='137' y='72' />
                          </annotation>
                          <annotation class='point' delta-type='added' id='1' mark-position='1' pullback='12' text-width='180'>
                            <formatted-text>
                              <run fontcolor='#000000' fontsize='8'>Australia primarily imported Petroleum, which is unsurprising considering the country&apos;s abundant domestic reserves of other mineral fuels.</run>
                              <run>Æ&#10;&#10;</run>
                              <run fontcolor='#787878' fontsize='8'>Subcategory: </run>
                              <run bold='true' fontsize='8'><![CDATA[<[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Subcategory:nk]>]]></run>
                              <run>Æ&#10;</run>
                              <run fontcolor='#787878' fontsize='8'>Trade Type: </run>
                              <run bold='true' fontsize='8'><![CDATA[<[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Trade Type:nk]>]]></run>
                              <run>Æ&#10;</run>
