                <story-points>
                  <story-point caption='Overall top import and Export goods' captured-sheet='Dashboard Category 3 Mineral fuels, lubricants and related materials' id='1'>
                    <capturedDeltas>
                      <worksheet name='Raw Dollar Pattern Category 3'>
                        <annotations>
                          <annotation class='point' delta-type='added' id='0' mark-position='1' pullback='12' text-width='372'>
                            <formatted-text>
                              <run fontalignment='0' fontcolor='#000000' fontsize='8'>Coal, coke, and briquettes emerging as the dominant export goods, consistently accounting for 59% of the total export value in this category.</run>
                              <run fontalignment='0'>Æ&#10;</run>
                              <run fontalignment='0' fontcolor='#787878' fontsize='8'>Subcategory: </run>
                              <run bold='true' fontalignment='0' fontsize='8'><![CDATA[<[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Subcategory:nk]>]]></run>
                              <run fontalignment='0'>Æ&#10;</run>
                              <run fontalignment='0' fontcolor='#787878' fontsize='8'>Trade Type: </run>
                              <run bold='true' fontalignment='0' fontsize='8'><![CDATA[<[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Trade Type:nk]>]]></run>
                              <run fontalignment='0'>Æ&#10;</run>
                              <run fontalignment='0' fontcolor='#787878' fontsize='8'>Avg. Trade Value: </run>
                              <run bold='true' fontalignment='0' fontsize='8'><![CDATA[<[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[avg:Trade Value:qk]>]]></run>
                            </formatted-text>
                            <point>
                              <visual-coordinate class='mark'>
                                <tuple-reference>
                                  <tuple-descriptor>
                                    <pane-descriptor>
                                      <x-fields />
                                      <y-fields />
                                    </pane-descriptor>
                                    <columns>
                                      <field>[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[avg:Trade Value:qk]</field>
                                      <field>[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Subcategory:nk]</field>
                                      <field>[federated.1oaal6x18aumuh16j7f0p1fzyjt5].[none:Trade Type:nk]</field>
